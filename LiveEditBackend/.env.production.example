# Production environment variables for Cloud Run
# DO NOT commit this file - set these in Cloud Run UI or via gcloud CLI

# AI Configuration (Vertex AI)
USE_VERTEX_AI=true
VERTEX_PROJECT_ID=rare-decker-488711-c0
VERTEX_LOCATION=us-central1

# Google Cloud Storage
GCS_BUCKET_NAME=liveedit
GCS_PROJECT_ID=rare-decker-488711-c0

# Models
GEMINI_TEXT_MODEL=gemini-2.0-flash
GEMINI_VIDEO_MODEL=gemini-2.0-flash

# Database (use Secret Manager reference in Cloud Run)
DATABASE_URL=postgresql://user:pass@host:5432/db

# Redis (use Secret Manager reference in Cloud Run)
REDIS_URL=rediss://user:pass@host:port

# Payment Gateway
PAYSTACK_SECRET_KEY=sk_live_xxx
PAYSTACK_PUBLIC_KEY=pk_live_xxx
PAYSTACK_CALLBACK_URL=https://rare-decker-488711-c0.web.app/payment/callback

# Frontend URL (set automatically by deploy script)
FRONTEND_URL=https://rare-decker-488711-c0.web.app

# Flask
FLASK_ENV=production
