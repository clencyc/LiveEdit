# Backend Environment Variables (.env)

# AI backend selection
USE_VERTEX_AI=true
VERTEX_PROJECT_ID=rare-decker-488711-c0
VERTEX_LOCATION=us-central1

# Optional: only needed if you still want Gemini Developer API for non-Vertex routes
GEMINI_API_KEY=your_gemini_api_key_here

# Database
DATABASE_URL=postgresql://username:password@localhost:5432/liveedit_db

# Paystack Configuration
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key_here
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key_here
PAYSTACK_CALLBACK_URL=https://your-domain.vercel.app/payment/callback

# Note: For production, use live keys:
# PAYSTACK_SECRET_KEY=sk_live_xxx
# PAYSTACK_PUBLIC_KEY=pk_live_xxx

# Google Cloud Storage (required for Vertex AI video ingestion)
GCS_BUCKET_NAME=your-gcs-bucket-name
GCS_PROJECT_ID=your-gcp-project-id
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Gemini model selection (supported defaults)
GEMINI_TEXT_MODEL=gemini-2.0-flash
GEMINI_VIDEO_MODEL=gemini-2.0-flash

# Gemini API timeout in seconds (increase for large video uploads >100MB)
# Default: 120 — raised from the SDK default of 30 to handle large videos
GEMINI_API_TIMEOUT=120
